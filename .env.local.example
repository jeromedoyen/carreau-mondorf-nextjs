# Copier en .env.local (déjà ignoré par git) et compléter avec les valeurs
# du projet Supabase (Project Settings > API).
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=

# Variables publiques (préfixe obligatoire Next.js) utilisées par l'appli
# elle-même pour lire les données en lecture seule.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
